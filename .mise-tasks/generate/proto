#!/usr/bin/env bun
//MISE description="Generate JavaScript packages based off the proto files for each service"

import { $ } from "bun";
import { readdirSync, statSync, rmdirSync, mkdirSync } from "fs";
import { join } from "path";

// Change into the proto directory where the central buf.yaml and buf.gen.yaml live
const protoDir = join(process.cwd(), "proto");

try {
  process.chdir(protoDir);
} catch (error) {
  console.error(`Failed to change directory to ${protoDir}`, error);
  process.exit(1);
}

const entries = readdirSync(".");

for (const entry of entries) {
  const isDir = statSync(entry).isDirectory();
  
  if (isDir) {
    console.log(`Generating ${entry}...`);
    const outDir = join("..", "gen", entry, "src", "gen");
    
    // Clean the old files and recreate the directory
    await $`rm -rf ${outDir}`;
    await $`mkdir -p ${outDir}`;
    
    // Use the central buf.gen.yaml and direct output to the target gen directory
    await $`buf generate --path ${entry} --template buf.gen.yaml --output ${outDir}`;
  }
}
